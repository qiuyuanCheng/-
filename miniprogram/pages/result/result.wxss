.result {
  min-height: 100vh;
  background: #030607;
  color: #f4f7fb;
}

button {
  margin: 18rpx 0;
}

.hero {
  border-color: rgba(255, 216, 107, 0.5);
  box-shadow: 0 0 28rpx rgba(255, 216, 107, 0.12);
}

.hero-main {
  font-size: 36rpx;
  font-weight: 1000;
  color: #ffd86b;
  margin-bottom: 8rpx;
}

.report-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.label {
  color: #9eb3bf;
  font-size: 22rpx;
}

.value {
  margin-top: 4rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.row-title {
  font-size: 26rpx;
  font-weight: 900;
  color: #ffffff;
  margin-bottom: 8rpx;
}
