.showcase {
  padding-bottom: 40rpx;
}
.grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 18rpx;
  margin-top: 22rpx;
}
.ball-card {
  box-sizing: border-box;
  background: #16242e;
  border: 1px solid #2a4552;
  border-radius: 8px;
  padding: 16rpx;
  min-height: 0;
  margin-bottom: 0;
}
.sprite-img {
  width: 100%;
  height: 190rpx;
  display: block;
  background: #081116;
  border-radius: 6px 6px 0 0;
}
.sprite-fallback {
  display: flex;
  align-items: center;
  justify-content: center;
}
.fallback-ball {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 28%, #ffe0aa 0%, #ff7b2d 34%, #ba240e 72%, #571006 100%);
  box-shadow: 0 0 28rpx rgba(255, 106, 42, 0.56), inset 0 0 16rpx rgba(255, 246, 196, 0.28);
  border: 4rpx solid #ff8a4a;
}
.info {
  margin-top: 12rpx;
}
.name {
  font-size: 28rpx;
  font-weight: 700;
}
.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 10rpx;
}
.tag {
  padding: 4rpx 10rpx;
  border-radius: 6px;
  background: rgba(25, 194, 177, 0.14);
  border: 1px solid rgba(25, 194, 177, 0.35);
  color: #d8fff9;
  font-size: 18rpx;
  line-height: 1.3;
}
.stat-line {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 23rpx;
  font-weight: 700;
  line-height: 1.4;
}
.desc {
  margin-top: 8rpx;
  color: #9eb3bf;
  font-size: 22rpx;
  line-height: 1.45;
}
.damage {
  color: #19c2b1;
}
.crit {
  color: #ffd86b;
}
.role {
  color: #ffffff;
  font-weight: 700;
}
.weak {
  color: #ffb6c4;
}
.sfx-btn {
  margin: 12rpx 0 0;
  border-radius: 8rpx;
  background: #153830;
  color: #d8fff9;
  border-color: #1e776b;
  font-weight: 800;
}
