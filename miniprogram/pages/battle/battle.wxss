.battle {
  height: 100vh;
  overflow: hidden;
  display: grid;
  grid-template-rows: auto minmax(0, 1fr) auto;
  background: #030607;
  color: #f4f7fb;
}

.top-hud {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  padding: 8rpx 14rpx 6rpx;
  background: linear-gradient(180deg, #0d1a20 0%, #081116 100%);
  border-bottom: 1rpx solid rgba(148, 190, 204, 0.22);
}

.fighter {
  position: relative;
  padding: 8rpx;
  border: 1rpx solid rgba(148, 190, 204, 0.28);
  border-radius: 8rpx;
  background: rgba(10, 22, 28, 0.92);
}

.fighter.team-a { box-shadow: inset 4rpx 0 0 #19c2b1; }
.fighter.team-b { box-shadow: inset 4rpx 0 0 #ff5f7d; }
.fighter.team-other { box-shadow: inset 4rpx 0 0 #f3d45c; }
.fighter.dead { opacity: 0.45; }

.fighter-main {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 8rpx;
  font-weight: 800;
}

.slot {
  color: #9eb3bf;
  font-size: 20rpx;
}

.name {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 22rpx;
}

.hp-text {
  font-size: 24rpx;
  color: #ffffff;
}

.hpbar {
  height: 8rpx;
  margin-top: 7rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #263f4b;
}

.hpfill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #19c2b1, #d8fff9);
  box-shadow: 0 0 16rpx rgba(25, 194, 177, 0.5);
}

.team-b .hpfill {
  background: linear-gradient(90deg, #ff5f7d, #ffd7df);
  box-shadow: 0 0 16rpx rgba(255, 95, 125, 0.5);
}

.team-other .hpfill {
  background: linear-gradient(90deg, #f3d45c, #fff2a8);
  box-shadow: 0 0 16rpx rgba(243, 212, 92, 0.46);
}

.badges {
  position: absolute;
  right: 10rpx;
  bottom: 18rpx;
  display: flex;
  gap: 6rpx;
}

.badges text {
  min-width: 28rpx;
  height: 28rpx;
  line-height: 28rpx;
  text-align: center;
  border-radius: 50%;
  background: #203743;
  color: #d8fff9;
  font-size: 18rpx;
  font-weight: 800;
}

.arena-wrap {
  position: relative;
  height: 100%;
  min-height: 0;
}

.arena {
  width: 100vw;
  height: 100%;
  min-height: 0;
  display: block;
}

.debug-panel {
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  z-index: 3;
  padding: 8rpx 12rpx;
  border-radius: 6rpx;
  background: rgba(0, 0, 0, 0.48);
  color: #d8fff9;
  font-size: 18rpx;
  font-weight: 700;
  pointer-events: none;
}

.vs-mask,
.victory-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(2, 8, 10, 0.42);
  pointer-events: none;
}

.vs-mask {
  flex-direction: column;
  gap: 22rpx;
}

.vs-row {
  width: 86%;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.vs-team {
  min-width: 0;
  padding: 18rpx;
  border: 2rpx solid rgba(216, 255, 249, 0.35);
  border-radius: 8rpx;
  background: rgba(8, 17, 22, 0.78);
}

.vs-name {
  font-size: 28rpx;
  font-weight: 900;
}

.vs-balls {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #ffffff;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vs-role {
  margin-top: 6rpx;
  color: #9eb3bf;
  font-size: 20rpx;
}

.vs-text {
  color: #ffffff;
  font-size: 54rpx;
  line-height: 1;
  font-weight: 1000;
  text-shadow: 0 0 24rpx rgba(216, 255, 249, 0.58);
}

.victory-mask {
  background: rgba(2, 8, 10, 0.28);
}

.victory-card {
  padding: 22rpx 42rpx;
  border: 1rpx solid rgba(216, 255, 249, 0.62);
  border-radius: 8rpx;
  background: rgba(8, 17, 22, 0.78);
  box-shadow: 0 0 32rpx rgba(25, 194, 177, 0.34);
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
}

.hud {
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 14rpx calc(6rpx + env(safe-area-inset-bottom));
  background: #081116;
  border-top: 1rpx solid rgba(148, 190, 204, 0.22);
}

.timebox {
  min-width: 0;
  display: grid;
  gap: 3rpx;
}

.time {
  font-size: 30rpx;
  font-weight: 900;
}

.event-list {
  display: grid;
  gap: 2rpx;
}

.event {
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: #9eb3bf;
  font-size: 20rpx;
}

.event-0 {
  color: #eefcff;
  font-weight: 700;
}

.event-1 { opacity: 0.72; }
.event-2 { opacity: 0.5; }

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
}

.actions button {
  min-width: 92rpx;
  margin: 0;
  border-radius: 8rpx;
  background: #153830;
  color: #d8fff9;
  border-color: #1e776b;
  font-weight: 800;
  font-size: 20rpx;
  line-height: 1.9;
  padding: 0 10rpx;
}
