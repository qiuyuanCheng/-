page {
  min-height: 100vh;
  background: #101820;
  color: #f4f7fb;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  border-radius: 8px;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
}

.panel {
  background: #16242e;
  border: 1px solid #2a4552;
  border-radius: 8px;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.muted {
  color: #9eb3bf;
  font-size: 26rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.primary {
  background: #19c2b1;
  color: #061716;
}

.secondary {
  background: #263945;
  color: #f4f7fb;
}
